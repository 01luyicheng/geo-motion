# OpenRouter API Key（必填）
# 在 https://openrouter.ai/keys 获取
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# 可选：AI 模型（默认使用 qwen/qwen3-vl-235b-a22b-instruct）
# 支持 OpenRouter 上所有视觉语言模型，例如：
#   qwen/qwen3-vl-235b-a22b-instruct  - 阿里通义千问多模态（推荐）
#   bytedance-seed/seed-2.0-mini      - 字节跳动 Seed
#   google/gemini-2.0-flash-exp       - Google Gemini Flash
OPENROUTER_MODEL=qwen/qwen3-vl-235b-a22b-instruct

# 可选：应用域名（用于 OpenRouter 来源标识）
NEXT_PUBLIC_BASE_URL=http://localhost:3000
