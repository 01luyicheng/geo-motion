# GeoMotion 环境变量配置示例
# 复制此文件为 .env，并填入实际值

# ============================================
# 必填项
# ============================================

# OpenRouter API Key（必填）
# 获取地址：https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# ============================================
# 可选项
# ============================================

# AI 模型选择（默认：qwen/qwen3-vl-235b-a22b-instruct）
# 支持的模型：
#   - qwen/qwen3-vl-235b-a22b-instruct  （阿里通义千问，推荐）
#   - bytedance-seed/seed-2.0-mini       （字节跳动 Seed）
#   - google/gemini-2.0-flash-exp        （Google Gemini）
OPENROUTER_MODEL=qwen/qwen3-vl-235b-a22b-instruct

# 应用域名（用于 OpenRouter 来源标识）
NEXT_PUBLIC_BASE_URL=http://localhost:3000
